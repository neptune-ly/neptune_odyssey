{
  "name": "@neptune.fintech/svelte-ui",
  "version": "1.0.0",
  "description": "Neptune Odyssey Svelte layer — a use:theme action, a NeptuneProvider, and theming re-exports over the framework-agnostic web kit.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Neptune.Fintech (https://neptune.ly)",
  "homepage": "https://neptune.ly",
  "repository": {
    "type": "git",
    "url": "https://github.com/neptune-ly/neptune_odyssey.git",
    "directory": "packages/neptune_svelte_ui"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./NeptuneProvider.svelte": "./src/components/NeptuneProvider.svelte",
    "./styles.css": "@neptune.fintech/web-ui/styles.css",
    "./package.json": "./package.json"
  },
  "files": ["dist", "src/components", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@neptune.fintech/tokens": "workspace:^",
    "@neptune.fintech/web-ui": "workspace:^"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
